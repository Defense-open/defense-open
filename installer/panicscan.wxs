<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 4 installer for PanicScan.

  Build command (run from repo root after cargo build):
    wix build installer/panicscan.wxs
         -d BinaryDir=target/release
         -d ProductVersion=0.1.0
         -o dist/panicscan-0.1.0-windows-x64.msi

  Requires: dotnet tool install global wix
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="PanicScan"
           Manufacturer="PanicScan"
           Version="$(var.ProductVersion)"
           UpgradeCode="8A3F1C2E-4B7D-4E9A-B0C1-D2E3F4A5B6C7"
           Scope="perMachine"
           Compressed="yes">

    <!-- Silently replace older versions; block downgrade -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed. Please uninstall it first." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Standard WiX minimal UI (welcome + install) -->
    <ui:WixUI Id="WixUI_Minimal" />

    <!-- Installation directory: C:\Program Files\PanicScan -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PanicScan" />
    </StandardDirectory>

    <!-- Start Menu shortcut directory -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PanicScan" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!-- Main binary -->
      <Component Id="MainExecutable">
        <File Id="MainExe"
              Source="$(var.BinaryDir)/panicscan.exe"
              KeyPath="yes" />

        <!-- Add install dir to System PATH so `panicscan` works in any terminal -->
        <Environment Id="AddToPath"
                     Name="PATH"
                     Value="[INSTALLFOLDER]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>

      <!-- Start Menu shortcut -->
      <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder">
        <Shortcut Id="AppStartMenuShortcut"
                  Name="PanicScan"
                  Description="Portable malware triage scanner"
                  Target="[INSTALLFOLDER]panicscan.exe"
                  Arguments="quick"
                  WorkingDirectory="INSTALLFOLDER" />
        <!-- Registry key so Windows Installer tracks this component -->
        <RegistryValue Root="HKCU"
                       Key="Software\PanicScan"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
        <RemoveFolder Id="CleanupStartMenuFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
      </Component>

    </ComponentGroup>

    <Feature Id="ProductFeature" Title="PanicScan" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

  </Package>
</Wix>
